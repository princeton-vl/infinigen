{
    "metadata": {},
    "data_types": {
        "rgb": {
            "original_path_template": "{scene}/{cam}/{frame:04d}.png",
            "packed_path_template": "{scene}/rgb-{cam}.mkv"
        },
        "rgb-denoised": {
            "original_path_template": "{scene}/{cam}/image-denoised_{frame:04d}.png",
            "packed_path_template": "{scene}/rgb-denoised-{cam}.mkv"
        },
        "diffuse-color": {
            "original_path_template": "{scene}/{cam}/diffuse-color_{frame:04d}.png",
            "packed_path_template": "{scene}/diffuse-color-{cam}.mkv"
        },
        "environment": {
            "original_path_template": "{scene}/{cam}/environment_{frame:04d}.png",
            "packed_path_template": "{scene}/environment-{cam}.mkv"
        },
        "depth": {
            "original_path_template": "{scene}/{cam}/depth_{frame:04d}.npy",
            "packed_path_template": "{scene}/depth-{cam}.mkv",
            "packing": {
                "method": "f32_as_log_int16",
                "min_orig_val": 0.05,
                "max_orig_val": 5633.0
            }
        },
        "optical-flow": {
            "original_path_template": "{scene}/{cam}/optical-flow_{frame:04d}.npy",
            "packed_path_template": "{scene}/optical-flow-{cam}.mkv",
            "packing": {
                "method": "linear",
                "min_orig_val": -500.0,
                "max_orig_val": 500.0,
                "from_dtype": "float32",
                "to_dtype": "uint16",
                "out_of_bounds_method": "nan_warn"
            }
        },
        "surface-normal": {
            "original_path_template": "{scene}/{cam}/surface-normal_{frame:04d}.npy",
            "packed_path_template": "{scene}/surface-normal-{cam}.mkv",
            "packing": {"method": "3f32_unit_sphere_as_2int16"}
        },
        "semantic-segmentation": {
            "original_path_template": "{scene}/{cam}/object_{frame:04d}.npy",
            "packed_path_template": "{scene}/semantic-segmentation-{cam}.mkv",
            "packing": {
                "method": "checkbounds",
                "from_dtype": "uint32",
                "to_dtype": "uint16",
                "min_orig_val": 0,
                "max_orig_val": 65535
            }
        },
        "material-segmentation": {
            "original_path_template": "{scene}/{cam}/material-index_{frame:04d}.npy",
            "packed_path_template": "{scene}/material-segmentation-{cam}.mkv",
            "packing": {
                "method": "checkbounds",
                "from_dtype": "uint32",
                "to_dtype": "uint16",
                "min_orig_val": 0,
                "max_orig_val": 65535
            }
        },
        "object-index-table": {
            "original_path_template": "{scene}/{cam}/object-index-table.json",
            "packed_path_template": "{scene}/object-index-table-{cam}.json"
        },
        "material-index-table": {
            "original_path_template": "{scene}/{cam}/material-index-table.json",
            "packed_path_template": "{scene}/material-index-table-{cam}.json"
        },
        "metadata": {
            "original_path_template": "{scene}/metadata.json",
            "packed_path_template": "{scene}/metadata.json"
        },
        "camera": {
            "original_path_template": "{scene}/{cam}/camera.npz",
            "packed_path_template": "{scene}/camera-{cam}.npz"
        }
    }
}
