include 'infinigen_examples/configs_nature/performance/dev.gin'

# Apple Silicon preset:
# - enables denoising
# - uses more samples than dev.gin (512) for quality
# - still far fewer than base.gin (8192) for speed
configure_render_cycles.denoise = True
configure_render_cycles.min_samples = 16
configure_render_cycles.num_samples = 1024
configure_render_cycles.adaptive_threshold = 0.01
